# Frontend - empty to use Vite proxy
VITE_API_URL=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prs_campaign

# Resend (Email) - get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Mistral (OCR) - get yours at https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
